<%
    var tocContents = toc(page.content, {list_number: false});
%>


<article class="post">
    <h1 class="post-title"><%=page.title%></h1>
    <% if (tocContents.length > 0) { %>
        <h2><%=__('post.toc')%></h2>
        <%-tocContents%>
        <br>
    <% } %>
    <%-page.content%>
</article>
<div class="post-footer">
    <div class="post-author">
        <span><%=__('post.created_at')%> <%=page.date.format('ll')%></span>
    </div>
    <div class="post-category">
        <% if (page.categories.length > 0) { %>
            <span>「<% page.categories.forEach(function(category, index) { %>
                        <% if (index>0) {%>、<% } %>
                        <a href="/categories/<%=category.name%>"><%=category.name%></a>
                    <% }); %>」
            </span>
        <% } %>
    </div>
    <div class="post-tags">
        <% if (page.tags.length > 0) { %>
            <% page.tags.forEach(function(tag, index) { %>
                <% if (index>0) {%>、<% } %>
                <a href="/tags/<%=tag.name%>">#<%=tag.name%></a>
            <% }); %>
        <% } %>
    </div>
    <% if (page.prev || page.next){ %>
        <div class="pagination">
            <% if (page.next){ %>
                <div class="nav-next nav-item">
                    <a href="<%- url_for(page.next.path) %>">
                        <i class="fa fa-angle-left"></i>
                        <span><%=page.next.title%></span>
                    </a>
                </div>
            <% } %>
            <% if (page.prev){ %>
                <div class="nav-prev nav-item">
                    <a href="<%- url_for(page.prev.path) %>">
                        <span><%=page.prev.title%></span>
                        <i class="fa fa-angle-right"></i>
                    </a>
                </div>
            <% } %>
        </div>
    <% } %>
</div>
<script src="https://giscus.app/client.js"
        data-repo="duskdusts/duskdusts.github.io"
        data-repo-id="MDEwOlJlcG9zaXRvcnkyNTg4MjY4NDg="
        data-category="Announcements"
        data-category-id="DIC_kwDOD21iYM4CSywL"
        data-mapping="pathname"
        data-strict="0"
        data-reactions-enabled="1"
        data-emit-metadata="0"
        data-input-position="top"
        data-theme="preferred_color_scheme"
        data-lang="zh-CN"
        data-loading="lazy"
        crossorigin="anonymous"
        async>
</script>

<% if (theme.mathjax){ %>
  <%- partial('mathjax') %>
<% } %>